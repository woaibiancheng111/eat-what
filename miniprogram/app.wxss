page {
  background: #09090b;
  color: #fafafa;
  font-family: 'Geist', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 32rpx 200rpx;
}

.hero {
  margin-bottom: 48rpx;
}

.hero-title {
  margin-bottom: 12rpx;
  color: #fafafa;
  font-size: 52rpx;
  font-weight: 800;
  letter-spacing: -0.03em;
}

.hero-subtitle {
  color: #a1a1aa;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.6;
}

.card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border: 1px solid #27272a;
  border-radius: 24rpx;
  background: #121215;
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
}

.card-interactive {
  transition: opacity 0.2s, transform 0.2s;
}

.card-hover {
  opacity: 0.85;
  transform: scale(0.99);
}

.form-card {
  padding: 40rpx 32rpx;
}

.section-title {
  margin-bottom: 24rpx;
  color: #71717a;
  font-size: 22rpx;
  font-weight: 700;
}

.section-note {
  color: #52525b;
  font-weight: 400;
  text-transform: none;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  border: 1px solid #c4b5fd;
  border-radius: 16rpx;
  background: #a78bfa;
  box-shadow: 0 0 20px rgba(167, 139, 250, 0.15);
  color: #0a0012;
  font-weight: 700;
  transition: transform 0.2s, box-shadow 0.2s;
}

.primary-button:active {
  transform: scale(0.98);
  background: #8b5cf6;
  box-shadow: 0 0 10px rgba(167, 139, 250, 0.3);
}

.secondary-button {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  border: 1px solid #3f3f46;
  border-radius: 16rpx;
  background: #18181b;
  color: #fafafa;
  font-weight: 600;
  transition: background 0.2s, color 0.2s;
}

.secondary-button:active {
  transform: scale(0.98);
  background: #27272a;
  color: #d4d4d8;
}

.destructive-button {
  border: 1px solid #7f1d1d;
  background: transparent;
  color: #ef4444;
}

.destructive-button:active {
  background: rgba(239, 68, 68, 0.1);
}

.fixed-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 50;
  display: flex;
  gap: 16rpx;
  padding: 32rpx;
  background: linear-gradient(to top, #09090b 80%, transparent);
}

.fixed-actions-row {
  flex-direction: row;
}

.fixed-actions-column {
  flex-direction: column;
}

.button-flex-1 {
  flex: 1;
}

.button-flex-strong {
  flex: 1.5;
}

.input {
  box-sizing: border-box;
  width: 100%;
  padding: 24rpx 32rpx;
  border: 1px solid #27272a;
  border-radius: 16rpx;
  background: #09090b;
  color: #fafafa;
}

.textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx 32rpx;
  border: 1px solid #27272a;
  border-radius: 16rpx;
  background: #09090b;
  color: #fafafa;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  padding: 0 24rpx;
  border: 1px solid #27272a;
  border-radius: 12rpx;
  background: #18181b;
  color: #a1a1aa;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.chip-active {
  border-color: #a78bfa;
  background: rgba(167, 139, 250, 0.1);
  color: #a78bfa;
}

.chip-compact {
  height: 48rpx;
  padding: 0 16rpx;
  font-size: 20rpx;
}

.chip-success {
  border-color: rgba(52, 211, 153, 0.3);
  background: rgba(52, 211, 153, 0.05);
  color: #34d399;
}

.wrap {
  display: flex;
  flex-wrap: wrap;
}

.gap-12 {
  gap: 12rpx;
}

.gap-16 {
  gap: 16rpx;
}

.helper-text {
  margin-top: 12rpx;
  color: #71717a;
  font-size: 24rpx;
  line-height: 1.6;
}

.search-section {
  margin-bottom: 48rpx;
}

.card-title {
  color: #fafafa;
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.favorite-mark {
  color: #a78bfa;
  font-size: 40rpx;
  text-shadow: 0 0 10px rgba(167, 139, 250, 0.5);
}

.card-tags {
  margin-top: 24rpx;
}

.card-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1px solid #27272a;
  color: #71717a;
  font-size: 20rpx;
}

.card-meta-value {
  color: #e4e4e7;
}

.card-meta-separator {
  padding: 0 8rpx;
  color: #3f3f46;
}

.slider-control {
  margin: 32rpx 0 16rpx;
}

.slider-value {
  color: #34d399;
  font-size: 32rpx;
  font-weight: 800;
}

.slider-value-neutral {
  color: #fafafa;
}

.switch-block + .switch-block {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 1px solid #27272a;
}

.switch-title {
  color: #fafafa;
  font-size: 28rpx;
  font-weight: 600;
}

.switch-title-accent {
  color: #a78bfa;
}

.switch-description {
  margin-top: 4rpx;
  color: #71717a;
  font-size: 20rpx;
  line-height: 1.6;
}

.form-field + .form-field {
  margin-top: 40rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-emoji {
  margin-bottom: 32rpx;
  font-size: 96rpx;
}

.empty-title {
  margin-bottom: 8rpx;
  color: #fafafa;
  font-size: 32rpx;
  font-weight: 700;
}
