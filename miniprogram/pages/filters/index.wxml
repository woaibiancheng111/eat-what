<view class="container">
  <view class="hero">
    <view class="hero-title">筛选条件</view>
    <view class="hero-subtitle">先缩小范围，再让首页帮你从更合适的候选里抽一个。</view>
  </view>

  <view class="card">
    <view class="row-between">
      <view class="section-title">最高预算档位</view>
      <view class="slider-value">{{filters.maxPriceLevel}}</view>
    </view>
    <slider class="slider-control" min="0" max="2" step="1" value="{{filters.maxPriceLevel - 1}}" bindchange="handlePriceChange" activeColor="#34d399" backgroundColor="#27272a" block-color="#fafafa" />
  </view>

  <view class="card">
    <view class="section-title">可接受距离</view>
    <view class="wrap gap-12">
      <view class="chip {{item.active ? 'chip-active' : ''}}" wx:for="{{distanceOptions}}" wx:key="level" data-level="{{item.level}}" bindtap="handleDistanceToggle">{{item.label}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">想吃的类型</view>
    <view class="wrap gap-12">
      <view class="chip {{item.active ? 'chip-active' : ''}}" wx:for="{{tagOptionItems}}" wx:key="label" data-tag="{{item.label}}" bindtap="handleTagToggle">{{item.label}}</view>
    </view>
  </view>

  <view class="card">
    <view class="row-between switch-block">
      <view>
        <view class="switch-title">只看正在营业</view>
        <view class="switch-description">避免抽到暂时吃不到的选项；是否排除今天刚吃过，请到设置页统一调整。</view>
      </view>
      <switch checked="{{filters.onlyOpen}}" color="#a78bfa" data-field="onlyOpen" bindchange="handleSwitch" />
    </view>
  </view>

  <view class="fixed-actions fixed-actions-row">
    <view class="secondary-button button-flex-1" bindtap="handleReset">重置</view>
    <view class="primary-button button-flex-strong" bindtap="handleApply">应用筛选</view>
  </view>
</view>
