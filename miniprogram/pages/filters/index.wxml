<view class="container">
  <view class="hero">
    <view class="hero-title">FILTERS</view>
    <view class="hero-subtitle">NARROW SCOPE</view>
  </view>
  <view class="card">
    <view class="row-between">
      <view class="section-title" style="margin-bottom: 0;">MAX PRICE LEVEL</view>
      <view style="color: #34d399; font-weight: 800; font-size: 32rpx;">{{filters.maxPriceLevel}}</view>
    </view>
    <slider style="margin: 32rpx 0 16rpx;" min="0" max="2" step="1" value="{{filters.maxPriceLevel - 1}}" bindchange="handlePriceChange" activeColor="#34d399" backgroundColor="#27272a" block-color="#fafafa" />
  </view>
  <view class="card">
    <view class="section-title">DISTANCE ZONES</view>
    <view class="wrap gap-12 mt-4">
      <view class="chip {{filters.distanceLevels.includes(1) ? 'chip-active' : ''}}" data-level="1" bindtap="handleDistanceToggle">Level 1</view>
      <view class="chip {{filters.distanceLevels.includes(2) ? 'chip-active' : ''}}" data-level="2" bindtap="handleDistanceToggle">Level 2</view>
      <view class="chip {{filters.distanceLevels.includes(3) ? 'chip-active' : ''}}" data-level="3" bindtap="handleDistanceToggle">Level 3</view>
    </view>
  </view>
  <view class="card">
    <view class="section-title">REQUIRE TAGS</view>
    <view class="wrap gap-12 mt-4">
      <view class="chip {{filters.selectedTags.includes(item) ? 'chip-active' : ''}}" wx:for="{{tagOptions}}" wx:key="*this" data-tag="{{item}}" bindtap="handleTagToggle">{{item}}</view>
    </view>
  </view>
  <view class="card">
     <view class="row-between" style="margin-bottom: 40rpx;">
      <view>
        <view style="font-weight: 600; font-size:28rpx;">STRICT: Only Open Now</view>
      </view>
      <switch checked="{{filters.onlyOpen}}" color="#a78bfa" data-field="onlyOpen" bindchange="handleSwitch" />
    </view>
    <view class="row-between pt-4" style="border-top: 1px solid #27272a; padding-top: 32rpx;">
      <view>
        <view style="font-weight: 600; font-size:28rpx;">Exclude Fresh</view>
        <view class="helper-text" style="margin-top: 4rpx; font-size: 20rpx;">Skip today's eaten items</view>
      </view>
      <switch checked="{{filters.excludeRecentlyEaten}}" color="#a78bfa" data-field="excludeRecentlyEaten" bindchange="handleSwitch" />
    </view>
  </view>
  <view class="fixed-actions" style="flex-direction: row;">
    <view class="secondary-button" style="flex: 1;" bindtap="handleReset">RESET</view>
    <view class="primary-button" style="flex: 1.5;" bindtap="handleApply">APPLY MATRIX</view>
  </view>
</view>