page {
  background-color: #09090b;
  color: #fafafa;
}

.page-container {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 60rpx;
}

.main-content {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 64rpx;
}

/* Hero Section */
.hero-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx 0;
}

.picker-container {
  position: relative;
}

.picker-glow {
  position: absolute;
  top: -32rpx;
  bottom: -32rpx;
  left: -32rpx;
  right: -32rpx;
  background-color: rgba(167, 139, 250, 0.2);
  border-radius: 50%;
  filter: blur(20px);
  opacity: 0.8;
  transition: opacity 0.3s;
}

.picker-button {
  position: relative;
  width: 384rpx;
  height: 384rpx;
  border-radius: 50%;
  background-color: #a78bfa;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 0 40px rgba(167, 139, 250, 0.3);
  border: 8rpx solid #c4b5fd;
  transition: transform 0.2s;
}

.picker-button:active {
  transform: scale(0.95);
}

.dice-icon {
  font-size: 80rpx;
  color: #0a0012;
}

.picker-text {
  color: #0a0012;
  font-weight: 900;
  font-size: 48rpx;
  letter-spacing: -0.05em;
}

.hero-sub {
  margin-top: 64rpx;
  color: #a1a1aa;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.05em;
}

/* Recommendation Section */
.recommendation-section {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.recommendation-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx;
}

.recommendation-title {
  font-size: 24rpx;
  font-weight: bold;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: #a78bfa;
}

.recommendation-badge {
  font-size: 20rpx;
  color: #52525b;
  background-color: #18181b;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  border: 1px solid #27272a;
}

.meal-card {
  background-color: #121215;
  border: 1px solid #27272a;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
}

.meal-image-wrap {
  height: 384rpx;
  width: 100%;
  position: relative;
}

.meal-image {
  width: 100%;
  height: 100%;
}

.meal-image-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to top, #09090b 5%, rgba(9, 9, 11, 0.3) 50%, transparent);
}

.meal-image-content {
  position: absolute;
  bottom: 32rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.meal-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #fafafa;
  letter-spacing: -0.025em;
}

.meal-tags {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.meal-tag-stars {
  font-size: 28rpx;
  color: #34d399;
}

.meal-tag-text {
  font-size: 24rpx;
  color: #a1a1aa;
  font-weight: 500;
}

.meal-details {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.meal-info-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 32rpx;
}

.info-block {
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 20rpx;
  color: #71717a;
  font-weight: bold;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.info-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #fafafa;
}

.text-accent {
  color: #34d399;
}

.info-divider {
  width: 1px;
  height: 64rpx;
  background-color: #27272a;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  background-color: #18181b;
  border: 1px solid #3f3f46;
  color: #fafafa;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  transition: background-color 0.2s;
}
.btn-primary:active {
  transform: scale(0.98);
  background-color: #27272a;
}

.btn-secondary {
  width: 100%;
  height: 96rpx;
  background-color: transparent;
  color: #71717a;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: color 0.2s;
}
.btn-secondary:active {
  color: #d4d4d8;
}

.empty-state {
  padding: 64rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}
.empty-icon {
  font-size: 100rpx;
}
.empty-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fafafa;
  margin-top: 32rpx;
}
.empty-desc {
  font-size: 28rpx;
  color: #a1a1aa;
  margin-top: 16rpx;
}

.mt-8 { margin-top: 32rpx; }

/* Bento Grid */
.bento-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.bento-item {
  background-color: #121215;
  border: 1px solid #27272a;
  padding: 32rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  transition: transform 0.2s;
}
.bento-item:active {
  transform: scale(0.98);
}

.bento-icon {
  font-size: 40rpx;
}

.bento-content {
  display: flex;
  flex-direction: column;
}

.bento-label {
  font-size: 20rpx;
  color: #71717a;
  font-weight: bold;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.bento-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #fafafa;
}

.truncate {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
