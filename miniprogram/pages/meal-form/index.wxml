<view class="container">
  <view class="hero">
    <view class="hero-title">{{id ? 'EDIT MEAL' : 'NEW MEAL'}}</view>
    <view class="hero-subtitle">CONFIGURE DATABASE</view>
  </view>
  <view class="card" style="padding: 40rpx 32rpx;">
    <view style="margin-bottom: 40rpx;">
      <view class="section-title">NAME</view>
      <input class="input" placeholder="e.g. Cyber Noodle" placeholder-style="color: #71717a;" data-field="name" bindinput="handleInput" value="{{name}}" />
    </view>
    <view style="margin-bottom: 40rpx;">
      <view class="section-title">TAGS <text style="text-transform:none; color:#52525b; font-weight:400;">(Space separated)</text></view>
      <input class="input" placeholder="e.g. Noodle Hot Spicy" placeholder-style="color: #71717a;" data-field="tagsText" bindinput="handleInput" value="{{tagsText}}" />
    </view>
    <view style="margin-bottom: 40rpx;">
      <view class="row-between">
        <view class="section-title" style="margin-bottom: 0;">PRICE LEVEL</view>
        <view style="color: #34d399; font-weight: 800; font-size:32rpx;">{{priceLevel}}</view>
      </view>
      <slider style="margin: 32rpx 0 16rpx;" min="0" max="2" step="1" value="{{priceLevel - 1}}" bindchange="handlePriceChange" activeColor="#a78bfa" backgroundColor="#27272a" block-color="#fafafa" />
    </view>
    <view style="margin-bottom: 40rpx;">
      <view class="row-between">
        <view class="section-title" style="margin-bottom: 0;">DISTANCE LEVEL</view>
        <view style="color: #fafafa; font-weight: 800; font-size:32rpx;">{{distanceLevel}}</view>
      </view>
      <slider style="margin: 32rpx 0 16rpx;" min="0" max="2" step="1" value="{{distanceLevel - 1}}" bindchange="handleDistanceChange" activeColor="#a78bfa" backgroundColor="#27272a" block-color="#fafafa" />
    </view>
    <view class="row-between" style="margin-bottom: 32rpx; padding-top: 32rpx; border-top: 1px solid #27272a;">
      <view style="font-weight: 600; font-size:28rpx;">Currently Open</view>
      <switch checked="{{isOpen}}" color="#a78bfa" data-field="isOpen" bindchange="handleSwitch" />
    </view>
    <view class="row-between">
      <view style="font-weight: 600; font-size:28rpx; color: #a78bfa;">Favorite</view>
      <switch checked="{{isFavorite}}" color="#a78bfa" data-field="isFavorite" bindchange="handleSwitch" />
    </view>
  </view>
  <view class="card" style="padding: 40rpx 32rpx;">
    <view class="section-title">NOTES</view>
    <textarea class="textarea" placeholder="Add any specific context or conditions..." placeholder-style="color: #71717a;" data-field="note" bindinput="handleInput" value="{{note}}"></textarea>
  </view>
  <view class="fixed-actions" style="flex-direction: column;">
    <view class="primary-button" bindtap="handleSave">SAVE ENTRY</view>
    <view wx:if="{{id}}" class="secondary-button destructive-button" bindtap="handleDelete">DELETE ENTRY</view>
  </view>
</view>