<view class="container">
  <view class="hero">
    <view class="hero-title">LIBRARY</view>
    <view class="hero-subtitle">YOUR LUNCH COLLECTION</view>
  </view>
  <view style="margin-bottom: 48rpx;">
    <input class="input" placeholder="Search meals or tags..." placeholder-style="color: #71717a;" bindinput="handleSearch" value="{{searchText}}" />
  </view>
  <view wx:if="{{meals.length}}">
    <view class="card" wx:for="{{meals}}" wx:key="id" data-id="{{item.id}}" bindtap="handleEdit" hover-class="opacity-80 transition-opacity">
      <view class="row-between">
        <view style="font-size: 36rpx; font-weight: 700; color: #fafafa; letter-spacing: -0.02em;">{{item.name}}</view>
        <view style="color: #a78bfa; font-size: 40rpx; text-shadow: 0 0 10px rgba(167,139,250,0.5);" wx:if="{{item.isFavorite}}">★</view>
      </view>
      <view class="wrap gap-12" style="margin-top: 24rpx;">
        <view class="chip" style="height: 48rpx; padding: 0 16rpx; font-size: 20rpx;" wx:for="{{item.tags}}" wx:key="*this">{{item}}</view>
        <view class="chip" style="height: 48rpx; padding: 0 16rpx; font-size: 20rpx; color: #34d399; border-color: rgba(52, 211, 153, 0.3); background: rgba(52, 211, 153, 0.05);">¥ Lvl {{item.priceLevel}}</view>
        <view class="chip" style="height: 48rpx; padding: 0 16rpx; font-size: 20rpx;">Dist {{item.distanceLevel}}</view>
      </view>
      <view class="helper-text" style="margin-top: 24rpx; font-size: 20rpx; text-transform: uppercase; letter-spacing: 0.05em; border-top: 1px solid #27272a; padding-top: 24rpx;">
        LAST ATE: <text style="color: #e4e4e7;">{{item.lastEatenAt ? item.lastEatenAt.slice(0, 10) : 'NEVER'}}</text> <text style="padding:0 8rpx;color:#3f3f46">|</text> TIMES: <text style="color: #e4e4e7;">{{item.eatCount || 0}}</text>
      </view>
    </view>
  </view>
  <view wx:else class="empty-state">
    <view class="empty-emoji">🍱</view>
    <view style="font-size: 32rpx; font-weight: bold; color: #fafafa; margin-bottom: 8rpx;">No meals found</view>
    <view class="helper-text">Add a new meal to expand your choices.</view>
  </view>
  <view class="fixed-actions">
    <view class="primary-button" bindtap="handleCreate">+ Add Meal</view>
  </view>
</view>