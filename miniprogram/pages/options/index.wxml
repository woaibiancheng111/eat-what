<view class="container options-page">
  <view class="options-hero">
    <view class="options-title">午餐库</view>
    <view class="options-subtitle">把你常吃、想吃的午饭都收进来，之后抽签会更靠谱。</view>
  </view>

  <view class="options-search">
    <view class="options-search-icon">⌕</view>
    <input class="input options-search-input" placeholder="搜索午餐名称或标签" placeholder-style="color: #52525b;" bindinput="handleSearch" value="{{searchText}}" />
  </view>

  <view wx:if="{{hasMeals}}" class="options-list">
    <view class="options-card" wx:for="{{meals}}" wx:key="id" data-id="{{item.id}}" bindtap="handleEdit" hover-class="card-hover">
      <view class="options-card-head">
        <view class="options-card-main">
          <view class="options-card-title">{{item.name}}</view>
          <view class="options-card-sub">{{item.primaryTag}}</view>
        </view>
        <view wx:if="{{item.isFavorite}}" class="options-card-star">✦</view>
      </view>

      <view class="options-chip-row wrap gap-12">
        <view class="chip chip-compact options-pill-primary">{{item.primaryTag}}</view>
        <view class="chip chip-compact" wx:for="{{item.secondaryTags}}" wx:key="id">{{item.label}}</view>
        <view class="chip chip-compact chip-success">预算 {{item.priceLevel}} 档</view>
        <view class="chip chip-compact">距离 {{item.distanceLevel}} 档</view>
      </view>

      <view class="options-meta-row">
        <view class="options-meta-item">
          <view class="options-meta-label">上次吃</view>
          <view class="options-meta-value">{{item.lastEatenLabel}}</view>
        </view>
        <view class="options-meta-divider"></view>
        <view class="options-meta-item">
          <view class="options-meta-label">累计次数</view>
          <view class="options-meta-value">{{item.eatCountLabel}} 次</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showSearchEmpty}}" class="empty-state options-empty-state">
    <view class="empty-emoji">🔎</view>
    <view class="empty-title">没有找到匹配的午餐项</view>
    <view class="helper-text">换个关键词试试，或者检查一下标签有没有写对。</view>
  </view>

  <view wx:if="{{showLibraryEmpty}}" class="empty-state options-empty-state">
    <view class="empty-emoji">🍱</view>
    <view class="empty-title">还没有午餐候选</view>
    <view class="helper-text">先添加几家常吃的店，首页才能帮你更快做决定。</view>
  </view>

  <view class="fixed-actions fixed-actions-row options-actions">
    <view class="primary-button" bindtap="handleCreate">+ 新增午餐项</view>
  </view>
</view>
